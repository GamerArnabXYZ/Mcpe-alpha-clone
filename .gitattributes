# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for source/build files
*.cpp text eol=lf
*.h   text eol=lf
*.c   text eol=lf
*.mk  text eol=lf
*.sh  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cmake text eol=lf
*.txt text eol=lf
*.md  text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.html text eol=lf
*.json text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.ogg binary
*.wav binary
*.zip binary
*.so  binary
*.apk binary
